# C2 Django AI Environment Configuration
# Copy this file to .env and update with your values

# === Database Configuration ===
POSTGRES_USER=myuser
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=mydb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# === Django Configuration ===
DJANGO_SECRET_KEY=CHANGE_THIS_SECRET_KEY_GENERATE_WITH_python-cdjango.core.management.utils.get_random_secret_key
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com
DJANGO_SETTINGS_MODULE=c2_core.settings

# === Redis Configuration ===
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# === Hasura Configuration ===
HASURA_GRAPHQL_ADMIN_SECRET=CHANGE_THIS_SECRET
HASURA_GRAPHQL_DATABASE_URL=postgres://myuser:CHANGE_THIS_PASSWORD@localhost:5432/mydb

# === AI Services Configuration ===
# Google Gemini API Key (https://makersuite.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Mistral AI API Key (https://console.mistral.ai/)
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# === CVE Intelligence Configuration ===
# NVD API Key (https://nvd.nist.gov/developers/request-an-api-key)
# Free to apply, increases rate limit from 5 req/30s to 50 req/30s
NVD_API_KEY=your_nvd_api_key_here

# VulnCheck API Key (optional, paid service — NOT YET IMPLEMENTED in backend)
# VULNCHECK_API_KEY=your_vulncheck_api_key_here

# CVE Cache TTL in seconds (default: 86400 = 24 hours)
CVE_CACHE_TTL=86400

# CVE Enrichment Batch Size (default: 50)
CVE_ENRICHMENT_BATCH_SIZE=50

# Enable CVE Sync (true/false)
CVE_SYNC_ENABLED=true

# CISA KEV Sync Schedule (cron format, default: daily at 2 AM UTC)
CISA_KEV_SYNC_SCHEDULE=0 2 * * *

# Prioritize local database for CVE queries (true/false)
CVE_LOCAL_DB_PRIORITY=true

# === LangChain / LangSmith Configuration (Phase 0) ===
# LangChain API Key for LangSmith tracing (https://smith.langchain.com/)
LANGCHAIN_API_KEY=your_langchain_api_key_here

# LangSmith Project Name
LANGCHAIN_PROJECT=c2-django-ai-auto

# LangSmith Endpoint
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# === Auto App LangChain Feature Flags ===
# Enable LangChain integration (true/false)
AUTO_USE_LANGCHAIN=false

# Enable LangSmith tracing (true/false)
AUTO_USE_LANGSMITH_TRACING=false

# Enable LangGraph workflows (true/false) - Phase 4 feature
AUTO_USE_LANGGRAPH_WORKFLOW=false

# Comma-separated list of agents to use LangChain for
# Options: ReconAgent,ExploitAgent,AutomationAgent,StrategyAgent
# Empty = use CAI for all agents
AUTO_LANGCHAIN_AGENTS=

# LLM Provider for Auto App (openai/anthropic/litellm)
AUTO_DEFAULT_LLM_PROVIDER=openai

# === Model configuration
AUTO_OPENAI_MODEL=gpt-4-turbo-preview
AUTO_ANTHROPIC_MODEL=claude-3-opus-20240229
AUTO_LITELLM_MODEL=gpt-4-turbo-preview
AUTO_MISTRAL_MODEL=mistral-small-2603
AUTO_DEEPSEEK_MODEL=deepseek-chat
AUTO_OLLAMA_MODEL=llama3

# LLM Parameters
AUTO_DEFAULT_TEMPERATURE=0.7
AUTO_DEFAULT_MAX_TOKENS=4096

# === Agent-Specific Model Configuration ===
# These configuration allow different agents to use different models
# Format: AGENT_<AGENT_ID>_MODEL=model_name
# Format: AGENT_<AGENT_ID>_PROVIDER=provider_name
# Format: AGENT_<AGENT_ID>_TEMPERATURE=temperature_value
# Format: AGENT_<AGENT_ID>_API_KEY=api_key
# Format: AGENT_<AGENT_ID>_API_BASE_URL=api_base_url
#
# Available providers: openai, anthropic, mistral, deepseek, ollama, litellm
#
# If not specified, agent will use AUTO_DEFAULT_LLM_PROVIDER and AUTO_DEFAULT_TEMPERATURE
# Priority of API configuration: agent-specific > provider-specific > global

# Initial Analyzer Agent (Database/Asset Analysis - 用于数据库初步分析)
# AGENT_INITIAL_ANALYZER_PROVIDER=openai
# AGENT_INITIAL_ANALYZER_MODEL=gpt-4-turbo-preview
# AGENT_INITIAL_ANALYZER_TEMPERATURE=0.0
# AGENT_INITIAL_ANALYZER_API_KEY=sk-your-specific-key
# AGENT_INITIAL_ANALYZER_API_BASE_URL=https://api.your-custom-provider.com/v1

# Automation Agent (Pentest Automation)
# AGENT_AUTOMATION_PROVIDER=openai
# AGENT_AUTOMATION_MODEL=gpt-4-turbo-preview
# AGENT_AUTOMATION_TEMPERATURE=0.0
# AGENT_AUTOMATION_API_KEY=sk-your-specific-key
# AGENT_AUTOMATION_API_BASE_URL=https://api.your-custom-provider.com/v1

# Skill Creator Agent
# AGENT_SKILL_CREATOR_PROVIDER=openai
# AGENT_SKILL_CREATOR_MODEL=gpt-4-turbo-preview
# AGENT_SKILL_CREATOR_TEMPERATURE=0.1
# AGENT_SKILL_CREATOR_API_KEY=sk-your-specific-key
# AGENT_SKILL_CREATOR_API_BASE_URL=https://api.your-custom-provider.com/v1

# Skill Verifier Agent
# AGENT_SKILL_VERIFIER_PROVIDER=openai
# AGENT_SKILL_VERIFIER_MODEL=gpt-4-turbo-preview
# AGENT_SKILL_VERIFIER_TEMPERATURE=0.0
# AGENT_SKILL_VERIFIER_API_KEY=sk-your-specific-key
# AGENT_SKILL_VERIFIER_API_BASE_URL=https://api.your-custom-provider.com/v1

# Skill Merger Evaluator Agent
# AGENT_SKILL_MERGER_EVALUATOR_PROVIDER=openai
# AGENT_SKILL_MERGER_EVALUATOR_MODEL=gpt-4-turbo-preview
# AGENT_SKILL_MERGER_EVALUATOR_TEMPERATURE=0.0
# AGENT_SKILL_MERGER_EVALUATOR_API_KEY=sk-your-specific-key
# AGENT_SKILL_MERGER_EVALUATOR_API_BASE_URL=https://api.your-custom-provider.com/v1

# Tool execution configuration
AUTO_MAX_TOOL_ITERATIONS=10
AUTO_TOOL_EXECUTION_TIMEOUT=300

# === Security Configuration ===
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-domain.com
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true

# === Logging Configuration ===
LOG_LEVEL=INFO
LOG_FILE=logs/c2_django.log
LOG_MAX_SIZE=50MB
LOG_BACKUP_COUNT=5

# === Scanning Configuration ===
MAX_CONCURRENT_SCANS=10
SCAN_TIMEOUT=300
SCAN_RETRY_COUNT=3

# Nmap Configuration
NMAP_OPTIONS=-sS -sV -O --max-retries 3
NMAP_TIMEOUT=300
NMAP_MAX_THREADS=10

# Subfinder Configuration
SUBFINDER_TIMEOUT=300
SUBFINDER_THREADS=10

# Nuclei Configuration
NUCLEI_TEMPLATES_PATH=~/.local/nuclei/templates
NUCLEI_RATE_LIMIT=10
NUCLEI_TIMEOUT=300

# === Performance Configuration ===
# Django Workers
UVICORN_WORKERS=9
UVICORN_BACKLOG=2048
UVICORN_LIMIT_CONCURRENCY=1000

# Celery Configuration
CELERY_WORKER_CONCURRENCY=100
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true

# === Monitoring Configuration ===
ENABLE_METRICS=false
METRICS_PORT=9090

# === Email Configuration (Optional) ===
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=your_email@gmail.com
EMAIL_HOST_PASSWORD=your_app_password

# === Backup Configuration ===
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=7
BACKUP_COMPRESSION=true

# === Development Settings ===
# Set to true only for development
ENABLE_DEBUG_TOOLBAR=false
ENABLE_DJANGO_DEBUG=false

# === External Service URLs ===
# These will be automatically configured based on your docker-compose setup
# DO NOT modify unless using external services

# Database URLs (Docker)
POSTGRES_DOCKER_URL=postgres://myuser:CHANGE_THIS_PASSWORD@postgres:5432/mydb
REDIS_DOCKER_URL=redis://redis:6379/0

# Service URLs
HASURA_URL=http://127.0.0.1:8085
NOCODB_URL=http://127.0.0.1:8081
FLARESOLVERR_URL=http://127.0.0.1:8191